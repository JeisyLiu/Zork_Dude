[
  {"id":"forest_entrance", "name":"迷雾森林入口", "emoji":"🌲", "map":{"layer":"surface","x":3,"y":3}, "desc":"浓雾笼罩的森林边缘。古木参天，灰雾流动。\n小路通向森林深处（north），西边有废弃小屋（west）。\n一个老人在墓碑旁驻着铁锹，似乎在等什么。", "exits":{"north":"dark_forest","west":"abandoned_hut"}, "npc_id":"gravedigger"},
  {"id":"abandoned_hut", "name":"废弃小屋", "emoji":"🏠", "map":{"layer":"surface","x":2,"y":3}, "desc":"破败的木屋，屋顶塌了一半。墙角有铁箱，桌上有提灯。\n角落里好像有什么东西在动……", "exits":{"east":"forest_entrance"}, "items":["rusty_key","lantern","old_coin"], "monster_id":"giant_rat"},
  {"id":"dark_forest", "name":"黑暗森林", "emoji":"🌳", "map":{"layer":"surface","x":3,"y":2}, "desc":"越来越暗。古树扭曲，雾中有影。远处有狼嚎。\n向西似乎有一座废弃的墓地，北通洞穴，东达十字路口。", "exits":{"south":"forest_entrance","north":"cave_entrance","east":"crossroads","west":"haunted_graveyard"}, "items":["old_sword","bread"], "monster_id":"wolf"},
  {"id":"cave_entrance", "name":"洞穴入口", "emoji":"🕳️", "map":{"layer":"cave","x":2,"y":0}, "desc":"漆黑的洞口，阴风阵阵。洞壁有刻痕。向下有通道。", "exits":{"south":"dark_forest","down":"cave_middle"}, "dark":true, "items":["torch","mushroom"]},
  {"id":"cave_middle", "name":"洞穴中层", "emoji":"🦇", "map":{"layer":"cave","x":2,"y":1}, "desc":"天然洞穴大厅，上方裂缝透光。洞壁发光苔藓。\n多条通道通向不同方向。", "exits":{"up":"cave_entrance","down":"cave_depths","east":"ancient_ruins","north":"goblin_cave","south":"underground_river"}, "dark":true, "items":["silver_key","lesser_potion"]},
  {"id":"cave_depths", "name":"洞穴深处", "emoji":"🕷️", "map":{"layer":"cave","x":2,"y":3}, "desc":"洞穴最深处，气味刺鼻。地上有白骨。\n巨大的蜘蛛在角落织网……", "exits":{"up":"cave_middle"}, "dark":true, "items":["golden_cup","spider_silk"], "monster_id":"giant_spider"},
  {"id":"ancient_ruins", "name":"远古遗迹", "emoji":"🗿", "map":{"layer":"cave","x":3,"y":1}, "desc":"石室，墙上刻满浮雕。中央石台有天鹅绒垫。\n东墙有石门。", "exits":{"west":"cave_middle","north":"hidden_passage"}, "items":["magic_scroll","ancient_scroll"]},
  {"id":"hidden_passage", "name":"秘密通道", "emoji":"🚪", "map":{"layer":"cave","x":3,"y":0}, "desc":"狭窄的通道，仅容一人通过。墙壁上有发光符文。\n通道尽头有向上的楼梯。", "exits":{"south":"ancient_ruins","up":"tower_base"}, "dark":true, "monster_id":"ghost"},
  {"id":"crossroads", "name":"十字路口", "emoji":"🛤️", "map":{"layer":"surface","x":4,"y":2}, "desc":"森林空地，五条路交汇。路牌：←湖 | 北：塔 | 南：森林 | 东：←", "exits":{"west":"dark_forest","north":"tower_base","east":"lake_shore","south":"forest_entrance"}, "npc_id":"old_hermit"},
  {"id":"tower_base", "name":"高塔底部", "emoji":"🏰", "map":{"layers":{"surface":{"x":4,"y":1},"tower":{"x":1,"y":2}}}, "desc":"古老石塔，爬满藤蔓。塔门紧闭，有特殊锁孔。", "exits":{"south":"crossroads","up":"tower_middle"}, "items":["journal","lesser_potion"]},
  {"id":"tower_middle", "name":"高塔中层", "emoji":"🌀", "map":{"layer":"tower","x":1,"y":1}, "desc":"塔内环形大厅，墙上挂满古老挂毯。\n螺旋楼梯继续向上。", "exits":{"down":"tower_base","up":"tower_top"}, "npc_id":"tower_guardian", "items":["crystal_key","magic_book"]},
  {"id":"tower_top", "name":"高塔顶层", "emoji":"🐉", "map":{"layer":"tower","x":1,"y":0}, "desc":"塔顶房间！堆满书籍和魔法器具。窗外是无尽迷雾。\n中央书桌上有一颗闪烁的魔法宝石。但一条幼龙盘踞在宝石旁边！", "exits":{"down":"tower_middle"}, "monster_id":"dragon_whelp"},
  {"id":"lake_shore", "name":"湖边", "emoji":"🌊", "map":{"layer":"surface","x":5,"y":2}, "desc":"宁静的湖泊，湖水清澈。小木船漂在湖面。\n南边有一个小村落。一个背着弓的老人在湖边钓鱼。", "exits":{"west":"crossroads","south":"lake_village"}, "npc_id":"hunter", "items":["compass","fishing_rod"]},
  {"id":"lake_village", "name":"湖边村", "emoji":"🏘️", "map":{"layer":"surface","x":5,"y":3}, "desc":"宁静的小渔村。几间木屋，炊烟袅袅。\n村口公告栏贴着告示。村中有酒馆、铁匠铺和神殿。", "exits":{"north":"lake_shore","south":"lake_village_inn","west":"lake_village_smithy","east":"lake_village_temple"}, "npc_id":"healer_lily", "items":["dried_meat","bread"]},
  {"id":"lake_island", "name":"湖心岛", "emoji":"🏝️", "map":{"layer":"surface","x":6,"y":2}, "desc":"岛上有神殿废墟。祭坛上的宝石被魔法屏障保护。\n水中有阴影游动……", "exits":{"west":"lake_shore"}, "monster_id":"shadow_beast", "items":["sacred_water","emerald"]},
  {"id":"goblin_cave", "name":"哥布林巢穴", "emoji":"👺", "map":{"layer":"cave","x":1,"y":1}, "desc":"股鼻的气味扑面而来！洞穴里堆满了偷来的杂物和骨头。\n一群哥布林正在分赃，看到你后尖叫着冲了过来！", "exits":{"south":"cave_middle"}, "dark":true, "items":["golden_cup","old_coin","lockpick","goblin_ear"], "monster_id":"goblin"},
  {"id":"goblin_throne", "name":"哥布林王座", "emoji":"👑", "map":{"layer":"cave","x":1,"y":0}, "desc":"洞穴最深处的一座天然石殿。一个巨大的哥布林坐在骨堆上。\n它头戴骨冠，手中巨棒上还沾着血迹——这就是哥布林王！", "exits":{"north":"goblin_cave"}, "dark":true, "items":["ancient_crown","rune_sword"], "monster_id":"goblin_king"},
  {"id":"underground_river", "name":"地下河", "emoji":"💧", "map":{"layer":"cave","x":2,"y":2}, "desc":"洞穴在这里豁然开朗，一条漆黑的地下河缓缓流过。\n河岸上有萤火虫般的发光苔藓，水中有东西在游动……", "exits":{"north":"cave_middle","east":"frozen_cave","west":"hidden_grove"}, "dark":true, "items":["fishing_rod","magic_herb","silver_ingot"], "monster_id":"giant_snake"},
  {"id":"frozen_cave", "name":"冰封洞穴", "emoji":"❄️", "map":{"layer":"cave","x":3,"y":2}, "desc":"洞穴的墙壁覆盖着厚厚的冰霜，温度骤降。\n呼出的气瞬间凝成白雾，地面结冰非常滑。\n一个由冰晶构成的生物在角落里静止不动……直到看见你。", "exits":{"west":"underground_river"}, "dark":true, "items":["ice_crystal","scale_armor","mana_potion"], "monster_id":"ice_elemental"},
  {"id":"hidden_grove", "name":"隐藏树丛", "emoji":"🌿", "map":{"layer":"cave","x":1,"y":2}, "desc":"一个被古老树木环绕的隐秘空地。阳光透过树叶洒下斑驳光影。\n空地中央有一座石头祭坛，周围长满了发光的草药。\n空气中充满了花香和魔法气息。", "exits":{"east":"underground_river"}, "npc_id":"wandering_rogue", "items":["fairy_dust","magic_herb","mushroom","health_ring"]},
  {"id":"bandit_camp", "name":"强盗营地", "emoji":"⛺", "map":{"layer":"surface","x":2,"y":4}, "desc":"森林深处的一片空地，搭着几个简陋的帐篷。篝火还在燃烧。\n几个面目狰狞的强盗正在分赃，看到你后纷纷拔出了武器！", "exits":{"north":"bandit_hideout","west":"forest_tower_ruins"}, "items":["old_coin","dried_meat","leather_armor"], "monster_id":"bandit_leader"},
  {"id":"bandit_hideout", "name":"强盗藏宝室", "emoji":"💎", "map":{"layer":"surface","x":1,"y":4}, "desc":"强盗们的秘密藏宝室！堆满了抢来的财物。\n角落里有一个巨大的宝箱……它在呼吸？！", "exits":{"south":"bandit_camp"}, "items":["gold_ingot","silver_ingot","ruby","sapphire","diamond"], "monster_id":"mimic"},
  {"id":"lake_village_inn", "name":"迷雾酒馆", "emoji":"🍺", "map":{"layer":"surface","x":5,"y":4}, "desc":"温暖的酒馆里弥漫着麦酒和烤肉的味道。壁炉里的火烧得正旺。\n墙上挂着各种猎物头颅，几个 locals 在角落里喝酒聊天。", "exits":{"south":"lake_village"}, "npc_id":"innkeeper", "items":["fish","bread","honey"]},
  {"id":"lake_village_smithy", "name":"铁匠铺", "emoji":"⚒️", "map":{"layer":"surface","x":4,"y":3}, "desc":"炙热的熔炉和叮当的锤声。墙上挂满了各种武器和防具。\n温度比外面高了不少。", "exits":{"east":"lake_village"}, "npc_id":"blacksmith", "items":["iron_sword","helmet","shield"]},
  {"id":"lake_village_temple", "name":"光之神殿", "emoji":"⛪", "map":{"layer":"surface","x":6,"y":3}, "desc":"一座小巧而庄严的神殿。彩色玻璃窗透入柔和的光芒。\n空气中弥漫着熏香的味道，让人心平气和。", "exits":{"west":"lake_village"}, "npc_id":"priestess", "items":["lesser_potion","sacred_water"]},
  {"id":"alchemist_lab", "name":"炼金术士的实验室", "emoji":"🧪", "map":{"layer":"cave","x":0,"y":2}, "desc":"一个堆满奇怪仪器和瓶瓶罐罐的洞穴实验室。\n五颜六色的液体在烧瓶中沸腾，空气中充满刺鼻气味。", "exits":{"west":"hidden_grove"}, "npc_id":"mad_alchemist", "items":["mana_potion","fairy_dust","mandrake_root"]},
  {"id":"forest_tower_ruins", "name":"森林塔废墟", "emoji":"🏚️", "map":{"layer":"surface","x":3,"y":4}, "desc":"一座倒塌了一半的古老石塔，被藤蔓和苔藓覆盖。\n塔内的螺旋楼梯已经断裂，但地下似乎还有空间。\n一只巨鹰在塔顶筑了巢。", "exits":{"south":"forest_entrance","west":"bandit_camp"}, "items":["phoenix_feather","ancient_scroll","mystic_amulet"], "monster_id":"giant_eagle"},
  {"id":"haunted_graveyard", "name":"被诅咒的墓地", "emoji":"🪦", "map":{"layer":"surface","x":2,"y":2}, "desc":"一片荒凉的墓地，墓碑歪歪斜斜地插在土中。\n阴冷的风穿过枯树发出呜咽声。地面下有东西在动……\n墓地的尽头有一座被藤蔓缠绕的石门。\n一个黑甲佣兵正在墓地中搜寻着什么。", "exits":{"west":"dark_forest"}, "npc_id":"bounty_hunter", "items":["old_coin","silver_ring","mystic_amulet"], "monster_id":"ghost"}
]
